<component type="desktop-application">
  <id>io.github.sofusa.qobine</id>
  <name>Qobine</name>
  <summary>Unofficial client for Qobuz</summary>

  <description>
    <p>Listening to your Qobuz music with Qobine: an Adwaita Qobuz client designed for GNOME.</p>
    <p>Upon first launch, a browser spawns where you will need to login to Qobuz with your active streaming subscription.</p>
    <p>Qobine is currently very mininal in terms of features, but more will follow.</p>
    <ul>
      <li>View and stream your favorite albums, artists and playlists</li>
      <li>Search the full Qobuz catalogue</li>
      <li>Add / remove favorites</li>
    </ul>
  </description>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <screenshots>
    <screenshot type="default">
      <image>https://github.com/SofusA/qobine/blob/main/assets/qobuz-player-gtk.png?raw=true</image>
    </screenshot>
  </screenshots>

  <launchable type="desktop-id">io.github.sofusa.qobine.desktop</launchable>

  <branding>
    <color type="primary" scheme_preference="light">#E0AE5B</color>
    <color type="primary" scheme_preference="dark">#6B5A40</color>
  </branding>

  <content_rating type="oars-1.1" />

  <developer id="io.github.sofusa">
    <name>Sofus Addington</name>
  </developer>

  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
  </recommends>

  <url type="homepage">https://github.com/SofusA/qobine</url>
  <url type="contribute">https://github.com/SofusA/qobine</url>
  <url type="vcs-browser">https://github.com/SofusA/qobine/qobuz-player-gtk</url>

  <releases>
